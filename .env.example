# Variables de entorno para producción (Vercel + Neon PostgreSQL)
# Copia este archivo como .env.local para desarrollo local

# ─── Base de Datos (Neon PostgreSQL) ───────────────────────────────────────────
# Obtén estos valores en: https://console.neon.tech → tu proyecto → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth.js ───────────────────────────────────────────────────────────────
# Genera un secret seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="tu_clave_secreta_aqui_generala_con_openssl"

# URL base de la aplicación (cambiar por tu dominio cuando tengas uno)
NEXTAUTH_URL="https://tu-proyecto.vercel.app"
